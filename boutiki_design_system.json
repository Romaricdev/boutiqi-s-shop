{
  "meta": {
    "project": "Boutiki",
    "version": "1.0.0",
    "description": "Design system complet pour la plateforme Boutiki — SaaS boutique WhatsApp Cameroun",
    "font_source": "Google Fonts",
    "last_updated": "2026-03"
  },

  "typography": {
    "fonts": {
      "display": {
        "family": "DM Serif Display",
        "google_import": "@import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display&display=swap')",
        "usage": "Logo wordmark et grands titres de landing page uniquement",
        "fallback": "Georgia, serif"
      },
      "body": {
        "family": "Plus Jakarta Sans",
        "google_import": "@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap')",
        "usage": "Toute l'interface — dashboard, boutique, formulaires, navigation",
        "weights": [400, 500, 600, 700],
        "fallback": "system-ui, -apple-system, sans-serif"
      }
    },
    "scale": {
      "h1": {
        "size": "28px",
        "weight": 700,
        "line_height": "1.2",
        "letter_spacing": "-0.5px",
        "font": "Plus Jakarta Sans",
        "usage": "Titre de page principal"
      },
      "h2": {
        "size": "22px",
        "weight": 600,
        "line_height": "1.3",
        "letter_spacing": "-0.3px",
        "font": "Plus Jakarta Sans",
        "usage": "Titre de section majeure"
      },
      "h3": {
        "size": "17px",
        "weight": 600,
        "line_height": "1.4",
        "letter_spacing": "0",
        "font": "Plus Jakarta Sans",
        "usage": "Sous-titre, en-tête de card"
      },
      "body_lg": {
        "size": "15px",
        "weight": 400,
        "line_height": "1.65",
        "letter_spacing": "0",
        "font": "Plus Jakarta Sans",
        "usage": "Texte courant principal"
      },
      "body": {
        "size": "14px",
        "weight": 400,
        "line_height": "1.6",
        "letter_spacing": "0",
        "font": "Plus Jakarta Sans",
        "usage": "Corps de texte standard, descriptions produit"
      },
      "body_medium": {
        "size": "14px",
        "weight": 500,
        "line_height": "1.6",
        "letter_spacing": "0",
        "font": "Plus Jakarta Sans",
        "usage": "Labels de formulaire, noms dans les listes"
      },
      "small": {
        "size": "12px",
        "weight": 400,
        "line_height": "1.5",
        "letter_spacing": "0",
        "font": "Plus Jakarta Sans",
        "usage": "Métadonnées, horodatages, texte secondaire"
      },
      "label": {
        "size": "11px",
        "weight": 600,
        "line_height": "1.4",
        "letter_spacing": "0.08em",
        "text_transform": "uppercase",
        "font": "Plus Jakarta Sans",
        "usage": "Labels de section, étiquettes de catégorie"
      },
      "price": {
        "size": "18px",
        "weight": 700,
        "line_height": "1.2",
        "letter_spacing": "-0.3px",
        "font": "Plus Jakarta Sans",
        "usage": "Prix produit, montants de commande"
      },
      "stat": {
        "size": "26px",
        "weight": 700,
        "line_height": "1.1",
        "letter_spacing": "-0.5px",
        "font": "Plus Jakarta Sans",
        "usage": "Valeurs dans les cartes métriques du dashboard"
      },
      "logo": {
        "size": "22px",
        "weight": 400,
        "line_height": "1",
        "letter_spacing": "-0.5px",
        "font": "DM Serif Display",
        "usage": "Wordmark Boutiki dans la navigation"
      }
    }
  },

